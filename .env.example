# Скопируйте в .env и при необходимости измените значения:
#   cp .env.example .env
#
# Production: не копируйте .env в образ. Платформа деплоя инжектирует те же
# переменные из secret store (K8s Secrets, Fly/Railway/ECS, CI secrets).
# Обязательно: DB_DSN (sslmode=require), SCHEDULER_API_KEY_REQUIRED=true,
# ключи из ./scripts/gen-api-keys.sh, R2_* при object-storage flow.

# PostgreSQL (сервис postgres)
POSTGRES_USER=video
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=video
POSTGRES_PORT=5432

# Миграции (cmd/migrate, сервис migrate в docker compose)
# DB_DSN=postgres://video:change-me-in-production@127.0.0.1:5432/video?sslmode=disable
# MIGRATE_BACKUP_DIR=db/backups
# MIGRATE_BACKUP_BEFORE=risky

# Scheduler (HTTP API)
SCHEDULER_PORT=8080
# Сгенерировать ключи: ./scripts/gen-api-keys.sh --format=env
# SCHEDULER_API_KEY_REQUIRED=false
# SCHEDULER_CLIENT_API_KEY=change-me-client
# SCHEDULER_WORKER_API_KEY=change-me-worker
# SCHEDULER_ADMIN_API_KEY=change-me-admin
# MAX_UPLOAD_BYTES=536870912
# SCHEDULER_UPLOAD_TIMEOUT=30m
# REAPER_INTERVAL=30s
# REAPER_WORKER_TIMEOUT=50s
# REAPER_ENABLED=true
# JOB_LEASE_DURATION=30m
# JOB_DEFAULT_MAX_DURATION=2h

# RabbitMQ (dispatch через transactional outbox; URL задаётся в docker-compose.yml)
# RABBITMQ_USER=guest
# RABBITMQ_PASSWORD=guest
# RABBITMQ_PORT=5672
# RABBITMQ_MGMT_PORT=15672
# OUTBOX_RELAY_INTERVAL=500ms
# OUTBOX_RELAY_BATCH=50

# Worker
WORKER_MAX_PARALLEL_JOBS=1
# SCHEDULER_WORKER_API_KEY=change-me-worker
# WORKER_GPU_AVAILABLE=false
# WORKER_TEMP_DIR=/tmp/jobs
# WORKER_LEASE_RENEW_INTERVAL=0
# WORKER_JOB_LEASE_DURATION=30m
# WORKER_DEFAULT_MAX_DURATION=2h
# Масштаб: docker compose up -d --scale worker=3

# Observability (docker-compose.observability.yml; make obs-up)
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=change-me
# CADVISOR_PORT=8081

# Cloudflare R2 (object storage — required for job logs; optional for local-path jobs without logs)
# Если заданы — доступны POST /jobs (multipart upload), /jobs/init и /jobs/{id}/submit
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET=video-jobs
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_REGION=auto
# R2_PRESIGN_UPLOAD_TTL=1h
# R2_PRESIGN_DOWNLOAD_TTL=1h
